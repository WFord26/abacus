# Abacus local environment template
#
# This repository does not yet auto-load one shared root .env into every app.
# Use this file as the source of truth for local values, then export the subset
# needed by the service or command you are running.

# Shared
NODE_ENV=development
HOST=127.0.0.1
JWT_SECRET=development-secret

# Local infrastructure
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_DB=accounting
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
REDIS_URL=redis://localhost:16379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_URL=http://127.0.0.1:9000
MINIO_CONSOLE_URL=http://127.0.0.1:9001

MAILHOG_SMTP_HOST=127.0.0.1
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_URL=http://127.0.0.1:8025

# Identity service
# Copy IDENTITY_DATABASE_URL into DATABASE_URL when running Prisma or the
# identity service because Prisma expects DATABASE_URL specifically.
IDENTITY_DATABASE_URL=postgresql://postgres:postgres@localhost:15432/accounting?schema=identity
IDENTITY_SERVICE_URL=http://127.0.0.1:3001
IDENTITY_PORT=3001

# Ledger service
LEDGER_DATABASE_URL=postgresql://postgres:postgres@localhost:15432/accounting?schema=ledger
LEDGER_SERVICE_URL=http://127.0.0.1:3002
LEDGER_PORT=3002

# Documents service
DOCUMENTS_DATABASE_URL=postgresql://postgres:postgres@localhost:15432/accounting?schema=documents
DOCUMENTS_SERVICE_URL=http://127.0.0.1:3004
DOCUMENTS_PORT=3004
DOCUMENTS_BUCKET=accounting-documents
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Reporting service
REPORTING_DATABASE_URL=postgresql://postgres:postgres@localhost:15432/accounting?schema=reporting
REPORTING_SERVICE_URL=http://127.0.0.1:3003
REPORTING_PORT=3003
REPORTS_BUCKET=accounting-reports

# API gateway
API_GATEWAY_PORT=3000
FRONTEND_ORIGIN=http://127.0.0.1:3007
INVOICING_SERVICE_URL=

# Web
WEB_PORT=3007
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3000/api/v1
